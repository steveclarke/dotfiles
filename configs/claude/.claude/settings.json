{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch",
      "Skill(*)",
      "mcp__plugin_context7_context7__*",
      "mcp__todoist__*",
      "mcp__pencil"
    ],
    "ask": [
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE\" == *.rb ]]; then cd \"$(git -C \"$(dirname \"$CLAUDE_FILE\")\" rev-parse --show-toplevel 2>/dev/null || dirname \"$CLAUDE_FILE\")\" && bundle exec standardrb --fix \"$CLAUDE_FILE\" 2>/dev/null; fi; exit 0",
            "statusMessage": "Running standardrb..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "stripe@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Working"
    ]
  },
  "effortLevel": "xhigh",
  "autoDreamEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
