{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "tui": {
    "scroll_acceleration": {
      "enabled": false
    },
    "scroll_speed": 1,
    "diff_style": "stacked"
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git add *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "git reset *": "ask",
      "git checkout *": "ask",
      "git rebase *": "ask",
      "git merge *": "ask",
      "git stash *": "ask",
      "git cherry-pick *": "ask",
      "git revert *": "ask",
      "git clean *": "ask",
      "git rm *": "ask",
      "git mv *": "ask",
      "git restore *": "ask"
    }
  },
  "mcp": {
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "enabled": true,
      "type": "local"
    }
  }
}