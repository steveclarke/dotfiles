{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (ubu)",
      "options": {
        "baseURL": "http://192.168.77.87:11434/v1"
      },
      "models": {
        "glm-4.7-flash": {
          "name": "GLM 4.7 Flash"
        },
        "gemma4:e4b": {
          "name": "Gemma 4 E4B"
        },
        "qwen3.5:9b": {
          "name": "Qwen 3.5 9B"
        }
      }
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git add *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "git reset *": "ask",
      "git checkout *": "ask",
      "git rebase *": "ask",
      "git merge *": "ask",
      "git stash *": "ask",
      "git cherry-pick *": "ask",
      "git revert *": "ask",
      "git clean *": "ask",
      "git rm *": "ask",
      "git mv *": "ask",
      "git restore *": "ask"
    }
  },
  "mcp": {
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "enabled": true,
      "type": "local"
    },
    "todoist": {
      "type": "remote",
      "url": "https://ai.todoist.net/mcp",
      "enabled": true
    }
  }
}