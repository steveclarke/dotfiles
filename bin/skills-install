#!/usr/bin/env bash
#
# skills-install — Sync all global skills from configured sources
#
# Installs or refreshes skills non-interactively across all agents (Claude Code,
# OpenCode, Codex, etc.) using symlinks (default behavior of skills.sh). Also
# prunes known deprecated skills that are no longer provided by configured
# sources.
#
# Usage:
#   skills-install          # sync all skills from all sources
#   skills-install --list   # list available skills without installing

set -euo pipefail

if [[ -z "${DOTFILES_DIR:-}" && -f "${HOME}/.dotfilesrc" ]]; then
  source "${HOME}/.dotfilesrc"
fi

if [[ -z "${DOTFILES_DIR:-}" ]]; then
  DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi

source "${DOTFILES_DIR}/lib/dotfiles.sh"

LIST_ONLY=false
if [[ "${1:-}" == "--list" || "${1:-}" == "-l" ]]; then
  LIST_ONLY=true
fi

DEPRECATED_SKILLS=(
  # Impeccable split skills (replaced by the consolidated impeccable skill)
  adapt
  animate
  arrange
  audit
  bolder
  clarify
  colorize
  critique
  delight
  distill
  extract
  frontend-design
  harden
  layout
  normalize
  onboard
  optimize
  overdrive
  polish
  quieter
  shape
  teach-impeccable
  typeset
  # Replaced by Doist's maintained todoist-cli skill (`td skill install <agent>`)
  todoist
)

install_all() {
  local label="$1"
  local source="$2"
  echo ""
  echo "=== ${label}: ${source}"
  echo ""
  if [[ "$LIST_ONLY" == "true" ]]; then
    npx -y skills add "$source" -g -l
  else
    npx -y skills add "$source" -g --all
  fi
}

install_specific() {
  local label="$1"
  local source="$2"
  shift 2
  local skills=("$@")
  echo ""
  echo "=== ${label}: ${source} (${#skills[@]} skills)"
  echo ""
  if [[ "$LIST_ONLY" == "true" ]]; then
    npx -y skills add "$source" -g -l
  else
    for skill in "${skills[@]}"; do
      npx -y skills add "$source" -g -y -s "$skill"
    done
  fi
}

remove_deprecated_skills() {
  local installed_deprecated=()
  local skill

  if [[ "$LIST_ONLY" == "true" ]]; then
    return
  fi

  if [[ "${DOTFILES_PRUNE_DEPRECATED_SKILLS:-true}" != "true" ]]; then
    return
  fi

  for skill in "${DEPRECATED_SKILLS[@]}"; do
    if [[ -e "${HOME}/.agents/skills/${skill}" ]]; then
      installed_deprecated+=("$skill")
    fi
  done

  if [[ "${#installed_deprecated[@]}" -eq 0 ]]; then
    return
  fi

  echo ""
  banner "Removing deprecated skills"
  echo ""
  npx -y skills remove -g -y "${installed_deprecated[@]}"
}

# ─── My custom skills (dotfiles repo) — install all ──────────────────────────
install_all "My skills (dotfiles)" \
  "https://github.com/steveclarke/dotfiles/tree/master/ai/skills"

# ─── My skills from own repos — install all ──────────────────────────────────
install_all "My skills (kiso)" \
  "https://github.com/steveclarke/kiso/tree/master/skills"

install_all "My skills (outport)" \
  "https://github.com/steveclarke/outport/tree/master/skills"

install_all "My skills (real-world-rails)" \
  "https://github.com/steveclarke/real-world-rails/tree/main/skills"

install_all "My skills (superthread)" \
  "https://github.com/steveclarke/superthread/tree/master/skills"

# ─── External: pbakaus/impeccable — install all ──────────────────────────────
install_all "External (impeccable)" \
  "pbakaus/impeccable"

# ─── External: android/skills — Google's Android agent skills ───────────────
install_all "External (android)" \
  "android/skills"

# ─── External: specific skills only ─────────────────────────────────────────

install_specific "External (antfu)" "antfu/skills" \
  slidev nuxt vite vitepress vitest vue vue-best-practices \
  vue-router-best-practices vue-testing-best-practices

install_specific "External (nuxt)" "nuxt/ui" \
  nuxt-ui

install_specific "External (shadcn)" "shadcn/ui" \
  shadcn

install_specific "External (vueuse)" "vueuse/skills" \
  vueuse-functions

install_specific "External (obie)" "obie/skills" \
  better-stimulus

install_specific "External (maquina-app)" "maquina-app/rails-upgrade-skill" \
  rails-upgrade-assistant

install_specific "External (intellectronica)" "intellectronica/agent-skills" \
  gog-cli

install_specific "External (doist)" "doist/todoist-cli" \
  todoist-cli

remove_deprecated_skills

echo ""
echo "✓ Done. Listing installed global skills:"
echo ""
npx -y skills ls -g
