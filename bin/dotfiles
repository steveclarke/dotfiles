#!/usr/bin/env bash

set -e -o pipefail

source "${HOME}"/.dotfilesrc
source "${DOTFILES_DIR}"/lib/dotfiles.sh

# Detect OS
detect_os

# Show usage if no command is provided
if [ $# -eq 0 ]; then
  echo "Usage: dotfiles <command>"
  echo ""
  echo "Commands:"
  echo "  up, update   Update everything (stow, brew, skills, mise)"
  echo "  stow         Update config symlinks"
  echo "  brew         Update and upgrade Homebrew packages"
  echo "  skills       Update agent skills"
  echo "  mise         Install/update tool versions"
  echo "  install      Run an install script (e.g. dotfiles install cloudflared)"
  exit 1
fi

run_stow() {
  banner "Stowing dotfiles"
  source "${DOTFILES_DIR}"/configs/stow.sh
}

run_brew() {
  banner "Updating Homebrew"
  brew update
  brew upgrade

  banner "Running brew bundle"

  if is_macos; then
    # Cache sudo credentials for casks that may require it
    cache_sudo_credentials

    if [[ -f "${DOTFILES_DIR}/Brewfile" ]]; then
      brew bundle --file="${DOTFILES_DIR}/Brewfile"
    fi

    if [[ -f "${DOTFILES_DIR}/Brewfile.macos" ]]; then
      brew bundle --file="${DOTFILES_DIR}/Brewfile.macos"
    fi
  else
    cd "${DOTFILES_DIR}" || exit
    brew bundle
    cd - > /dev/null || exit
  fi

  banner "Cleaning up Homebrew"
  brew cleanup
}

run_skills() {
  banner "Updating agent skills"
  "${DOTFILES_DIR}/bin/skills-update"
}

run_mise() {
  banner "Updating mise tools"
  mise install
}

run_install() {
  local name="$1"
  if [[ -z "$name" ]]; then
    echo "Usage: dotfiles install <script-name>"
    echo "Example: dotfiles install cloudflared"
    exit 1
  fi

  # Search for the install script across platform-specific and shared directories
  local search_dirs=("${DOTFILES_DIR}/install/optional")
  if is_arch; then
    search_dirs=("${DOTFILES_DIR}/install/arch/cli" "${DOTFILES_DIR}/install/arch/apps" "${search_dirs[@]}")
  elif is_macos; then
    search_dirs=("${DOTFILES_DIR}/install/macos" "${search_dirs[@]}")
  else
    search_dirs=("${DOTFILES_DIR}/install/cli" "${DOTFILES_DIR}/install/apps" "${search_dirs[@]}")
  fi

  for dir in "${search_dirs[@]}"; do
    if [[ -f "${dir}/${name}.sh" ]]; then
      source "${dir}/${name}.sh"
      return
    fi
  done

  error "No install script found for '${name}'"
  exit 1
}

# check the command and run appropriate function
case $1 in
  up|update)
    run_stow
    run_brew
    run_skills
    run_mise
    ;;
  stow)
    run_stow
    ;;
  brew)
    run_brew
    ;;
  skills)
    run_skills
    ;;
  mise)
    run_mise
    ;;
  install)
    run_install "$2"
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'dotfiles' for usage"
    exit 1
    ;;
esac
