#!/usr/bin/env bash

set -e -o pipefail

source "${HOME}"/.dotfilesrc
source "${DOTFILES_DIR}"/lib/dotfiles.sh

# Detect OS
detect_os

# Show usage if no command is provided
if [ $# -eq 0 ]; then
  echo "Usage: dotfiles <command>"
  echo ""
  echo "Commands:"
  echo "  up, update          Update everything (stow, brew, skills, mise)"
  echo "  stow                Update config symlinks"
  echo "  brew                Update and upgrade Homebrew packages"
  echo "  skills [subcmd]     Manage agent skills (install, update, list, status)"
  echo "  mise                Install/update tool versions"
  echo "  install <name>      Run an install script (e.g. dotfiles install cloudflared)"
  exit 1
fi

run_stow() {
  banner "Stowing dotfiles"
  source "${DOTFILES_DIR}"/configs/stow.sh
}

run_brew() {
  if ! is_installed brew; then
    banner "Skipping Homebrew — not installed on this system"
    return 0
  fi

  banner "Updating Homebrew"
  brew update
  brew upgrade

  banner "Running brew bundle"

  if is_macos; then
    # Cache sudo credentials for casks that may require it
    cache_sudo_credentials

    if [[ -f "${DOTFILES_DIR}/Brewfile" ]]; then
      brew bundle --file="${DOTFILES_DIR}/Brewfile"
    fi

    if [[ -f "${DOTFILES_DIR}/Brewfile.macos" ]]; then
      brew bundle --file="${DOTFILES_DIR}/Brewfile.macos"
    fi
  else
    cd "${DOTFILES_DIR}" || exit
    brew bundle
    cd - > /dev/null || exit
  fi

  banner "Cleaning up Homebrew"
  brew cleanup
}

SKILLS_DIR="${HOME}/.agents/skills"

# `skills add` always fetches the latest copy, so install == update. We expose
# both verbs so the CLI reads naturally, but they share one implementation.
run_skills_install() {
  banner "Installing/updating agent skills"
  "${DOTFILES_DIR}/bin/skills-install"
}

run_skills_list() {
  banner "Configured skill sources"
  grep -E '^install_(all|specific) ' "${DOTFILES_DIR}/bin/skills-install" \
    | sed -E 's/^install_(all|specific) "([^"]+)" *\\?$/  - \2/' \
    | sed -E 's/^install_(all|specific) "([^"]+)" *"([^"]*)".*/  - \2 (\3)/'
  echo
  if [[ -d "$SKILLS_DIR" ]]; then
    local count
    count=$(find "$SKILLS_DIR" -maxdepth 1 -mindepth 1 -type d | wc -l)
    echo "Installed: ${count} skill(s) in ${SKILLS_DIR}"
  else
    echo "Installed: (none — ${SKILLS_DIR} does not exist)"
  fi
}

run_skills_status() {
  banner "Skills status"
  if [[ -d "$SKILLS_DIR" ]]; then
    local count
    count=$(find "$SKILLS_DIR" -maxdepth 1 -mindepth 1 -type d | wc -l)
    success "${count} skill(s) installed at ${SKILLS_DIR}"
  else
    error "Skills dir missing: ${SKILLS_DIR}"
  fi
  for agent_dir in "$HOME/.claude/skills" "$HOME/.config/opencode/skill" "$HOME/.config/crush/skills" "$HOME/.config/goose/skills" "$HOME/.cursor/skills" "$HOME/.codex/skills"; do
    if [[ -e "$agent_dir" ]]; then
      local agent_count
      agent_count=$(find "$agent_dir" -maxdepth 1 -mindepth 1 | wc -l)
      success "Agent dir: ${agent_dir} (${agent_count} entries)"
    fi
  done
}

run_skills() {
  case "${1:-install}" in
    install|update)  run_skills_install ;;
    list|ls)         run_skills_list ;;
    status)          run_skills_status ;;
    -h|--help|help)
      echo "Usage: dotfiles skills <subcommand>"
      echo ""
      echo "Subcommands:"
      echo "  install   Install/refresh all configured skills (idempotent)"
      echo "  update    Alias for install — 'skills add' always fetches latest"
      echo "  list      Show configured sources and installed count"
      echo "  status    Skills dir + agent dir counts"
      ;;
    *)
      error "Unknown skills subcommand: $1"
      echo "Run 'dotfiles skills help' for usage"
      exit 1
      ;;
  esac
}

run_mise() {
  banner "Updating mise tools"
  mise install
}

run_install() {
  local name="$1"
  if [[ -z "$name" ]]; then
    echo "Usage: dotfiles install <script-name>"
    echo "Example: dotfiles install cloudflared"
    exit 1
  fi

  # Search for the install script across platform-specific and shared directories
  local search_dirs=("${DOTFILES_DIR}/install/optional")
  if is_arch; then
    search_dirs=("${DOTFILES_DIR}/install/arch/cli" "${DOTFILES_DIR}/install/arch/apps" "${search_dirs[@]}")
  elif is_macos; then
    search_dirs=("${DOTFILES_DIR}/install/macos" "${search_dirs[@]}")
  else
    search_dirs=("${DOTFILES_DIR}/install/cli" "${DOTFILES_DIR}/install/apps" "${search_dirs[@]}")
  fi

  for dir in "${search_dirs[@]}"; do
    if [[ -f "${dir}/${name}.sh" ]]; then
      source "${dir}/${name}.sh"
      return
    fi
  done

  error "No install script found for '${name}'"
  exit 1
}

# check the command and run appropriate function
case $1 in
  up|update)
    run_stow
    run_brew
    run_skills_install
    run_mise
    ;;
  stow)
    run_stow
    ;;
  brew)
    run_brew
    ;;
  skills)
    shift
    run_skills "$@"
    ;;
  mise)
    run_mise
    ;;
  install)
    run_install "$2"
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'dotfiles' for usage"
    exit 1
    ;;
esac
