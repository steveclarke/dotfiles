#!/usr/bin/env bash
#
# skills-migrate — One-time migration from symlink-based skills to npx-based
#
# Replaces the old approach (whole-directory symlinks from stow) with the new
# approach (per-skill symlinks via npx skills / bin/skills-install).
#
# What it does:
#   1. Pulls latest dotfiles (which removed external skills from ai/skills/)
#   2. Removes stale whole-directory symlinks for skills/commands/agents
#   3. Creates real directories where npx skills expects them
#   4. Removes the old lock file for a clean install
#   5. Runs skills-install to install everything fresh
#
# Safe to run multiple times. Delete this script after migration.
#
# Usage:
#   skills-migrate           # run the migration
#   skills-migrate --dry-run # show what would happen without doing it

set -euo pipefail

DRY_RUN=false
if [[ "${1:-}" == "--dry-run" ]]; then
  DRY_RUN=true
fi

RESET="\033[0m"
GREEN="\033[32m"
YELLOW="\033[33m"
DIM="\033[2m"

info()    { printf "%s\n" "$1"; }
success() { printf "  ${GREEN}✓${RESET} %s\n" "$1"; }
skip()    { printf "  ${DIM}· %s (already done)${RESET}\n" "$1"; }
warn()    { printf "  ${YELLOW}! %s${RESET}\n" "$1"; }

run() {
  if [[ "$DRY_RUN" == "true" ]]; then
    printf "  ${DIM}[dry-run] %s${RESET}\n" "$*"
  else
    "$@"
  fi
}

# Stale symlinks from the old stow-based approach
STALE_SYMLINKS=(
  "$HOME/.claude/skills"
  "$HOME/.claude/commands"
  "$HOME/.agents/skills"
  "$HOME/.cursor/skills"
  "$HOME/.cursor/commands"
  "$HOME/.config/opencode/skill"
  "$HOME/.config/opencode/command"
)

# Directories that npx skills needs to exist as real dirs
REQUIRED_DIRS=(
  "$HOME/.claude/skills"
  "$HOME/.agents/skills"
)

echo ""
info "Skills Migration: symlinks → npx skills"
echo ""

# ── Step 1: Pull latest dotfiles ────────────────────────────────────────────
info "Step 1: Pull latest dotfiles"

DOTFILES_DIR="$(cd "$(dirname "$0")/.." && pwd)"
if [[ -d "$DOTFILES_DIR/.git" ]]; then
  pushd "$DOTFILES_DIR" > /dev/null
  if run git pull --ff-only; then
    success "Pulled latest"
  else
    warn "git pull failed — continuing with current state"
  fi
  popd > /dev/null
else
  warn "Not a git repo at $DOTFILES_DIR — skipping pull"
fi
echo ""

# ── Step 2: Remove stale symlinks ───────────────────────────────────────────
info "Step 2: Remove stale symlinks"

for link in "${STALE_SYMLINKS[@]}"; do
  if [[ -L "$link" ]]; then
    run rm "$link"
    success "Removed $link"
  elif [[ -e "$link" ]]; then
    skip "$link (not a symlink, leaving alone)"
  else
    skip "$link (doesn't exist)"
  fi
done
echo ""

# ── Step 3: Create required directories ─────────────────────────────────────
info "Step 3: Create required directories"

for dir in "${REQUIRED_DIRS[@]}"; do
  if [[ -d "$dir" ]]; then
    skip "$dir"
  else
    run mkdir -p "$dir"
    success "Created $dir"
  fi
done
echo ""

# ── Step 4: Clean lock file ─────────────────────────────────────────────────
info "Step 4: Clean lock file"

LOCK_FILE="$HOME/.agents/.skill-lock.json"
if [[ -f "$LOCK_FILE" ]]; then
  run rm "$LOCK_FILE"
  success "Removed $LOCK_FILE"
else
  skip "No lock file to remove"
fi
echo ""

# ── Step 5: Install skills ──────────────────────────────────────────────────
if [[ "$DRY_RUN" == "true" ]]; then
  info "Step 5: [dry-run] Would run: skills-install"
else
  info "Step 5: Installing skills via skills-install"
  echo ""
  "$DOTFILES_DIR/bin/skills-install"
fi

echo ""
info "Migration complete. You can delete this script:"
info "  rm $DOTFILES_DIR/bin/skills-migrate"
echo ""
